  },
  {
    city: "Austin",
    state: "TX",
    zip: "78701",
    desc: "Serving Round Rock, Cedar Park, Georgetown & the greater ATX area.",
    keyword: "Washer Repair Austin",
  },
  {
    city: "San Antonio",
    state: "TX",
    zip: "78201",
    desc: "Covering Helotes, Schertz, New Braunfels & surrounding communities.",
    keyword: "Appliance Repair San Antonio",
  },
  {
    city: "Fort Worth",
    state: "TX",
    zip: "76101",
    desc: "Serving Arlington, Mansfield, Burleson & all mid-cities communities.",
    keyword: "Dryer Repair Fort Worth",
  },
