</header>

<!-- ============================================================
     HERO SECTION
     ============================================================ -->
<section
  id="hero"
  aria-label="Hero section"
  class="relative overflow-hidden bg-gradient-to-br from-[#1e3a8a] via-[#1e40af] to-[#0f2057] text-white"
>
  <!-- Background decorative circles -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-orange-500/10 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-white/3 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <!-- Left: Copy -->
      <div>
        <!-- Same-Day Service Badge -->
        <div class="inline-flex items-center gap-2 bg-orange-500/20 border border-orange-400/40 text-orange-300 rounded-full px-4 py-1.5 text-sm font-semibold mb-6">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-orange-400"></span>
          </span>
          Same-Day Service Available — Texas Wide
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight mb-6">
          Fast &amp; Reliable
          <span class="text-orange-400 block">Washer &amp; Dryer</span>
          Repair in Texas
        </h1>

        <p class="text-blue-100 text-lg sm:text-xl leading-relaxed mb-8 max-w-xl">
          Serving Dallas, Houston, Austin, San Antonio &amp; Fort Worth. Licensed technicians, OEM parts, and a 90-day warranty on every repair — guaranteed.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 mb-10">
          <a
            href={PHONE_HREF}
            id="hero-call-btn"
            class="flex items-center justify-center gap-2.5 bg-orange-500 hover:bg-orange-400 text-white font-bold text-lg px-8 py-4 rounded-xl shadow-2xl shadow-orange-500/30 hover:shadow-orange-500/50 transition-all duration-200 hover:scale-105"
          >
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
            </svg>
            Call Now: {PHONE}
          </a>
          <a
            href="#services"
            id="hero-services-btn"
            class="flex items-center justify-center gap-2 border-2 border-white/30 hover:border-white/60 text-white font-semibold text-lg px-8 py-4 rounded-xl transition-all duration-200 hover:bg-white/10"
          >
            View Our Services
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
            </svg>
          </a>
        </div>

        <!-- Trust Badges -->
        <div class="flex flex-wrap gap-4">
          {[
            { icon: "✅", text: "Licensed & Insured" },
            { icon: "🛡️", text: "90-Day Warranty" },
            { icon: "⚡", text: "Same-Day Service" },
            { icon: "💲", text: "Upfront Pricing" },
          ].map(badge => (
            <div class="flex items-center gap-1.5 text-blue-100 text-sm font-medium">
              <span>{badge.icon}</span>
              <span>{badge.text}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Trust Card -->
      <div class="hidden lg:block">
        <div class="bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-8 shadow-2xl">
          <h2 class="text-2xl font-bold text-white mb-6 text-center">Get Same-Day Service</h2>
          <div class="space-y-4 mb-8">
            {[
              { label: "📍 Your Location", hint: "Dallas, Houston, Austin & more" },
              { label: "🔧 Appliance Type", hint: "Washer, Dryer, or Both" },
              { label: "⚠️ Issue Description", hint: "Describe what's wrong" },
            ].map(field => (
              <div>
                <p class="text-blue-200 text-xs font-semibold uppercase tracking-wider mb-1">{field.label}</p>
                <div class="bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-blue-100/60 text-sm italic">
                  {field.hint}
                </div>
              </div>
            ))}
          </div>
          <a
            href={PHONE_HREF}
            class="block text-center bg-orange-500 hover:bg-orange-400 text-white font-bold text-lg py-4 rounded-xl transition-all duration-200 hover:scale-105 shadow-lg mb-4"
          >
            📞 Call {PHONE}
          </a>
          <p class="text-center text-blue-200 text-xs">Average response time: <strong class="text-white">under 2 hours</strong></p>
          <div class="flex justify-center gap-1 mt-3">
            {[1,2,3,4,5].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#f59e0b" class="w-5 h-5">
                <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401Z" clip-rule="evenodd" />
              </svg>
            ))}
          </div>
          <p class="text-center text-blue-200 text-xs mt-1">4.9/5 based on 500+ Texas reviews</p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ============================================================
     STATS BAR
     ============================================================ -->
<section aria-label="Company statistics" class="bg-[#0f2057] text-white py-6">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <ul class="grid grid-cols-2 lg:grid-cols-4 gap-6 text-center">
      {stats.map(stat => (
        <li class="py-2">
          <p class="text-3xl sm:text-4xl font-extrabold text-orange-400">{stat.value}</p>
          <p class="text-blue-200 text-sm font-medium mt-1">{stat.label}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<!-- ============================================================
