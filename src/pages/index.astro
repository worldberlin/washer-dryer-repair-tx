    badge: "OEM Quality",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-10 h-10"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" /></svg>`,
    title: "Our Expert Process",
    desc: "15+ years of appliance repair experience. Our structured 4-step diagnostic process ensures an accurate fix the first time — every time.",
    badge: "15+ Years",
  },
];

const testimonials = [
  {
    name: "Maria T.",
    city: "Dallas, TX",
    stars: 5,
    text: "My Samsung washer was flooding the laundry room. I called at 8am and the technician arrived by 11am. Fixed in under 2 hours. Professional, clean, and affordable. Will absolutely call again!",
    service: "Washer Repair",
  },
  {
    name: "James R.",
    city: "Houston, TX",
    stars: 5,
    text: "Dryer stopped producing heat — total nightmare with 3 kids. These guys came the same day, showed me exactly what the issue was, and had it running perfectly. Highly recommend for anyone in Houston!",
    service: "Dryer Repair",
  },
  {
    name: "Linda K.",
    city: "Austin, TX",
    stars: 5,
    text: "Two other companies couldn't figure out my Whirlpool washer. One call here and a licensed tech fixed it in one visit. Transparent pricing, no games. This is the only appliance repair company I'll use.",
    service: "Washer Repair",
  },
];

const faqs = [
  {
    q: "How quickly can a technician come out?",
    a: "We offer same-day service 7 days a week across all major Texas cities. Call before noon and we'll typically dispatch a technician the same day. Evening appointments are also available.",
  },
  {
    q: "What appliance brands do you repair?",
    a: "We repair all major brands including Samsung, LG, Whirlpool, Maytag, Kenmore, GE Appliances, Bosch, Frigidaire, Amana, Speed Queen, and many more.",
  },
  {
    q: "Do you offer a warranty on repairs?",
    a: "Absolutely. Every repair we complete is backed by a 90-day parts and labor warranty. If the same issue returns within 90 days, we come back at no additional charge.",
  },
  {
    q: "Are your technicians licensed and insured?",
    a: "Yes. All our technicians are EPA-certified, background-checked, fully licensed for appliance repair in Texas, and carry full liability insurance for your protection.",
  },
  {
    q: "How much does washer or dryer repair cost?",
    a: "Most repairs range from $75 to $350 depending on the issue and parts required. We always provide a firm flat-rate quote before any work begins — zero hidden fees, ever.",
  },
  {
    q: "Do you service both electric and gas dryers?",
    a: "Yes, we repair both electric and gas dryers from all major manufacturers. Our technicians are certified to work on both types safely and efficiently.",
  },
];

const stats = [
  { value: "15+", label: "Years Experience" },
  { value: "10K+", label: "Repairs Completed" },
  { value: "Same-Day", label: "Service Available" },
  { value: "90-Day", label: "Repair Warranty" },
];
---

<Layout
  title="Texas Washer & Dryer Repair | Same-Day Service | Dallas, Houston, Austin"
  description="Professional washer and dryer repair across Texas. Same-day service in Dallas, Houston, Austin, San Antonio & Fort Worth. Licensed technicians, 90-day warranty. Call now!"
  keywords="washer repair Dallas, dryer service Houston, emergency appliance repair Texas, washer repair Austin, dryer repair San Antonio, appliance repair Fort Worth"
>

<!-- ============================================================
     ANNOUNCEMENT BAR
     ============================================================ -->
<div class="bg-orange-500 text-white text-center py-2 px-4 text-sm font-semibold tracking-wide">
  🔧 Same-Day Service Available Across Texas &nbsp;|&nbsp; 7 Days a Week &nbsp;|&nbsp;
  <a href={PHONE_HREF} class="underline font-bold hover:text-orange-100 transition-colors">
    Call {PHONE}
  </a>
</div>

<!-- ============================================================
     STICKY NAVIGATION
     ============================================================ -->
<header id="site-header" class="sticky top-0 z-50 bg-[#1e3a8a] shadow-lg">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between" aria-label="Main navigation">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group" aria-label="Texas Washer & Dryer Repair Home">
      <div class="w-10 h-10 bg-orange-500 rounded-lg flex items-center justify-center group-hover:bg-orange-400 transition-colors flex-shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="white" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" />
        </svg>
      </div>
      <div class="hidden sm:block">
        <p class="text-white font-bold text-lg leading-tight">TX Washer &amp; Dryer</p>
        <p class="text-blue-200 text-xs font-medium tracking-wide">APPLIANCE REPAIR</p>
      </div>
    </a>

    <!-- Desktop Nav Links -->
    <ul class="hidden lg:flex items-center gap-8 text-sm font-semibold text-blue-100">
      <li><a href="#services" class="hover:text-white transition-colors">Services</a></li>
      <li><a href="#process" class="hover:text-white transition-colors">Our Process</a></li>
      <li><a href="#service-areas" class="hover:text-white transition-colors">Service Areas</a></li>
      <li><a href="#faq" class="hover:text-white transition-colors">FAQ</a></li>
    </ul>

    <!-- CTA Phone -->
    <a
      href={PHONE_HREF}
      id="nav-call-btn"
      class="flex items-center gap-2 bg-orange-500 hover:bg-orange-400 text-white font-bold px-5 py-2.5 rounded-lg transition-all duration-200 shadow-md hover:shadow-orange-500/30 hover:scale-105 text-sm"
      aria-label={`Call us at ${PHONE}`}
    >
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
