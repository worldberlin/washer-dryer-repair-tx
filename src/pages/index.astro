  { name: "LG",         color: "#A50034" },
  { name: "Whirlpool",  color: "#003087" },
  { name: "Maytag",     color: "#003594" },
  { name: "Kenmore",    color: "#C8122A" },
  { name: "GE",         color: "#4A90E2" },
  { name: "Bosch",      color: "#C8122A" },
  { name: "Frigidaire", color: "#003087" },
