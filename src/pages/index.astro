const process = [
  {
    step: "01",
    title: "Call or Book Online",
    desc: "Reach us 7 days a week. We'll confirm your appointment in minutes — same-day slots are available across all Texas service areas.",
  },
  {
    step: "02",
    title: "Expert Diagnosis",
    desc: "Our licensed technician arrives on schedule, performs a thorough diagnosis, and explains the issue in plain language — no jargon.",
  },
  {
    step: "03",
