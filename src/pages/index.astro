const serviceAreas = [
  {
    city: "Dallas",
    state: "TX",
    zip: "75201",
    desc: "Serving Uptown, Oak Cliff, East Dallas, Plano, Garland & beyond.",
    keyword: "Washer Repair Dallas",
  },
  {
    city: "Houston",
    state: "TX",
    zip: "77001",
